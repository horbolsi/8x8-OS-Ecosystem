# 8x8 Hub Environment Variables
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/hub_db

# Server
HUB_PORT=3000
NODE_ENV=production
ADMIN_SECRET=change_me_in_production

# Telegram
TG_BOT_TOKEN=your_telegram_bot_token

# AI Providers
ELEVENLABS_API_KEY=your_elevenlabs_key
FAL_KEY=your_fal_key
OPENROUTER_API_KEY=your_openrouter_key

# Trading
BITGET_API_KEY=your_bitget_key
BITGET_SECRET_KEY=your_bitget_secret
BITGET_PASSPHRASE=your_bitget_passphrase

# CORS
ALLOWED_ORIGINS=http://localhost:8086,http://localhost:3000
